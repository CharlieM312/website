{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:monorepos",
    "group:recommended"
  ],
  "minimumReleaseAge": "3 days",
  "prCreation": "not-pending",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "groupName": "Angular ecosystem",
      "matchPackageNames": [
        "/^@angular//",
        "/^angular-eslint/"
      ]
    },
    {
      "groupName": "Jest testing suite",
      "matchPackageNames": [
        "/^jest/",
        "/^@types/jest/"
      ]
    },
    {
      "groupName": "ESLint tooling",
      "matchPackageNames": [
        "/^eslint/",
        "/^typescript-eslint/",
        "/^globals/"
      ]
    }
  ]
}
