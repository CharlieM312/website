    "compilerOptions": {
        "outDir": "./out-tsc/spec",
        "types": ["jasmine", "node", "jest"],
        "module": "commonjs",
        "target": "es2018",
        "moduleResolution": "node16",
        "sourceMap": true
    },
    "include": ["src/**/*.spec.ts", "src/**/*.d.ts"]
}